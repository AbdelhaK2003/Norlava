# Database
# For local PostgreSQL: postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
# For Supabase: Get from https://app.supabase.com/project/_/settings/database
# For Neon: Get from https://console.neon.tech/app/projects
DATABASE_URL="postgresql://postgres:password@localhost:5432/voxterna"

# AI Configuration
GEMINI_API_KEY="your-gemini-api-key-here"

# Security
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Environment
NODE_ENV="development"
SIMULATED_AI="false"
